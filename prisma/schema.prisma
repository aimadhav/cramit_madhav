// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum ContentType {
  text
  image
  latex
  audio
  mixed
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  phone     String?
  isPremium Boolean  @default(false)
  isAdmin   Boolean  @default(false)
  
  // Study stats
  totalCardsStudied Int @default(0)
  totalTimeStudied  Int @default(0) // in minutes
  streakDays        Int @default(0)
  lastStudyDate     DateTime?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  decks             Deck[]
  flashcardStatuses UserFlashcardStatus[]
  studySessions     StudySession[]
}

model Deck {
  id          String    @id @default(cuid())
  name        String
  description String?
  tagsJson    String    @default("[]") // JSON array of strings
  isPremium   Boolean   @default(false)
  isPublic    Boolean   @default(false)
  price       Float?
  coverImage  String?
  subject     String?
  chapter     String?
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // Relations
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcards  Flashcard[]

  @@index([isPublic])
  @@index([subject])
  @@index([isPremium])
}

model Flashcard {
  id          String      @id @default(cuid())
  front       String
  back        String
  contentType ContentType @default(text)
  mediaUrlsJson String    @default("[]") // JSON array of strings
  tagsJson    String      @default("[]") // JSON array of strings
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  
  // Relations
  deckId      String
  deck        Deck        @relation(fields: [deckId], references: [id], onDelete: Cascade)
  userStatuses UserFlashcardStatus[]
}

model UserFlashcardStatus {
  id           String    @id @default(cuid())
  userId       String
  flashcardId  String
  
  // Spaced Repetition System (SRS) fields
  interval     Int       @default(1)     // Days until next review
  easeFactor   Float     @default(2.5)   // How easy the card is
  repetitions  Int       @default(0)     // Number of times reviewed
  dueDate      DateTime  @default(now()) // When card is due for review
  lastReviewed DateTime?                 // Last review timestamp
  
  // User-specific metadata
  isBookmarked Boolean   @default(false)
  isLearned    Boolean   @default(false)
  isDeleted    Boolean   @default(false) // Soft delete from user's view
  
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  
  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  flashcard    Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)

  @@unique([userId, flashcardId])
  @@index([dueDate])
  @@index([userId, dueDate])
}

model StudySession {
  id           String    @id @default(cuid())
  deckId       String
  userId       String
  startTime    DateTime  @default(now())
  endTime      DateTime?
  cardsStudied Int       @default(0)
  cardsCorrect Int       @default(0)
  
  createdAt    DateTime  @default(now())
  
  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([deckId])
}